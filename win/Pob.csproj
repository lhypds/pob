<Project Sdk="Microsoft.NET.Sdk">

  <!-- Pob Windows shell. A feature-for-feature port of the macOS/Linux shells
       built with C# / WPF. See win/README.md. -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>Pob</AssemblyName>
    <RootNamespace>Pob</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Allows compiling (not running) this Windows-only app on macOS/Linux,
         e.g. win/build.sh and win/build_docker.sh. -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <!-- App.xaml lives under src/, outside the SDK's root-only convention. -->
  <ItemGroup>
    <ApplicationDefinition Include="src\App.xaml" />
    <Page Remove="src\App.xaml" />
  </ItemGroup>

</Project>
