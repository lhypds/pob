<Window x:Class="Pob.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Pob.Views"
        Title="Pob"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        MinWidth="400"
        MinHeight="300">
    <!-- Translucent gray background: SwiftUI Color.gray.opacity(0.2). -->
    <Grid x:Name="Root" Background="#338E8E93">
        <views:ContentView x:Name="ContentArea"/>
    </Grid>
</Window>
